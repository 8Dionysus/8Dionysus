#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_HINT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
SOURCE_ROOT=""
SOURCE_REF="origin/main"
PASSTHROUGH_ARGS=()

while (($#)); do
  case "$1" in
    --source-root)
      if (($# < 2)); then
        echo "--source-root requires a path" >&2
        exit 2
      fi
      SOURCE_ROOT="$2"
      shift 2
      ;;
    --source-root=*)
      SOURCE_ROOT="${1#*=}"
      shift
      ;;
    --source-ref)
      if (($# < 2)); then
        echo "--source-ref requires a Git ref" >&2
        exit 2
      fi
      SOURCE_REF="$2"
      shift 2
      ;;
    --source-ref=*)
      SOURCE_REF="${1#*=}"
      shift
      ;;
    *)
      PASSTHROUGH_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -n "${SOURCE_ROOT}" ]]; then
  if [[ ! -f "${SOURCE_ROOT}/scripts/project_workspace_root.py" ]]; then
    echo "Selected source root has no scripts/project_workspace_root.py: ${SOURCE_ROOT}" >&2
    exit 2
  fi
  REPO_ROOT="$(cd "${SOURCE_ROOT}" && pwd)"
  if [[ -f "${ROOT_HINT}/8Dionysus/scripts/project_workspace_root.py" ]]; then
    WORKSPACE_ROOT="${ROOT_HINT}"
  else
    WORKSPACE_ROOT="$(cd "${REPO_ROOT}/.." && pwd)"
  fi
elif [[ -f "${ROOT_HINT}/scripts/project_workspace_root.py" ]]; then
  REPO_ROOT="${ROOT_HINT}"
  WORKSPACE_ROOT="$(cd "${REPO_ROOT}/.." && pwd)"
elif [[ -f "${ROOT_HINT}/8Dionysus/scripts/project_workspace_root.py" ]]; then
  WORKSPACE_ROOT="${ROOT_HINT}"
  REPO_ROOT="${WORKSPACE_ROOT}/8Dionysus"
else
  echo "Could not locate 8Dionysus/scripts/project_workspace_root.py from ${SCRIPT_DIR}" >&2
  exit 1
fi

HEAD_COMMIT="$(git -C "${REPO_ROOT}" rev-parse HEAD 2>/dev/null || true)"
REF_COMMIT="$(git -C "${REPO_ROOT}" rev-parse --verify "${SOURCE_REF}^{commit}" 2>/dev/null || true)"
if [[ -z "${HEAD_COMMIT}" || -z "${REF_COMMIT}" || "${HEAD_COMMIT}" != "${REF_COMMIT}" ]]; then
  echo "Refusing workspace projection from a non-current owner source." >&2
  echo "source_root=${REPO_ROOT}" >&2
  echo "source_ref=${SOURCE_REF}" >&2
  echo "head_commit=${HEAD_COMMIT:-unavailable}" >&2
  echo "source_ref_commit=${REF_COMMIT:-unavailable}" >&2
  echo "Use --source-root <clean-current-8Dionysus-checkout> or reconcile the canonical owner checkout." >&2
  exit 2
fi

python3 "${REPO_ROOT}/scripts/project_workspace_root.py" \
  --source-root "${REPO_ROOT}" \
  --source-ref "${SOURCE_REF}" \
  --workspace-root "${WORKSPACE_ROOT}" \
  --require-current-source \
  "${PASSTHROUGH_ARGS[@]}"
