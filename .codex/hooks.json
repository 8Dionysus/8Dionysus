{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/srv/.codex/hooks/aoa_session_start.py'",
            "statusMessage": "AoA session-start trace",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/srv/.codex/hooks/aoa_user_prompt_submit.py'",
            "statusMessage": "AoA prompt trace",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/srv/.codex/hooks/aoa_stop_doctor.py'",
            "statusMessage": "AoA stop doctor",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
