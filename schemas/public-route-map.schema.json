{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus/schemas/public-route-map.schema.json",
  "title": "8Dionysus public route map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_ref",
    "posture",
    "validation_refs",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": "8dionysus_public_route_map_v2"
    },
    "schema_ref": {
      "const": "schemas/public-route-map.schema.json"
    },
    "owner_repo": {
      "const": "8Dionysus"
    },
    "surface_kind": {
      "const": "orientation_surface"
    },
    "authority_ref": {
      "type": "string",
      "const": "docs/PUBLIC_ENTRY_POSTURE.md"
    },
    "posture": {
      "type": "string",
      "const": "route-map-only"
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "routes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "need",
        "canonical_repo",
        "capsule_ref",
        "authority_ref",
        "verification_refs"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "minLength": 1
        },
        "need": {
          "type": "string",
          "minLength": 1
        },
        "canonical_repo": {
          "type": "string",
          "minLength": 1
        },
        "capsule_ref": {
          "type": "string",
          "minLength": 1
        },
        "authority_ref": {
          "type": "string",
          "minLength": 1
        },
        "verification_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
