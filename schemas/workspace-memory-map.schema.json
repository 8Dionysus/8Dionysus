{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.dev/schemas/workspace-memory-map.schema.json",
  "title": "OS Abyss workspace memory overlay map",
  "type": "object",
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "generated_by",
    "workspace_root_hint",
    "taxonomy",
    "writeback_surface",
    "reviewed_memory_owner",
    "session_evidence_owner",
    "access_plane",
    "totals",
    "places"
  ],
  "properties": {
    "schema_version": {
      "const": "8dionysus_workspace_memory_map_v1"
    },
    "schema_ref": {
      "const": "schemas/workspace-memory-map.schema.json"
    },
    "owner_repo": {
      "const": "8Dionysus"
    },
    "surface_kind": {
      "const": "workspace_memory_overlay_map"
    },
    "generated_by": {
      "const": "scripts/build_workspace_memory_map.py"
    },
    "workspace_root_hint": {
      "type": "string"
    },
    "taxonomy": {
      "type": "object",
      "required": [
        "port_levels",
        "writeback_decisions",
        "writeback_marker_statuses",
        "writeback_debt_statuses",
        "live_writeback_debt_statuses",
        "meaning"
      ],
      "properties": {
        "port_levels": {
          "type": "array",
          "items": {
            "enum": [
              "none",
              "route_only",
              "stub_port",
              "full_port",
              "mature_port"
            ]
          },
          "minItems": 5,
          "maxItems": 5
        },
        "meaning": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "writeback_decisions": {
          "type": "array",
          "items": {
            "enum": [
              "write_candidate",
              "prepare_export",
              "reviewed_write",
              "no_writeback_needed",
              "route_only_debt",
              "needs_owner_review",
              "blocked"
            ]
          },
          "minItems": 7,
          "maxItems": 7
        },
        "writeback_marker_statuses": {
          "type": "array",
          "items": {
            "enum": [
              "present",
              "missing",
              "not_applicable",
              "unknown"
            ]
          },
          "minItems": 4,
          "maxItems": 4
        },
        "writeback_debt_statuses": {
          "type": "array",
          "items": {
            "enum": [
              "live_check_required",
              "needs_marker",
              "not_applicable",
              "unknown"
            ]
          },
          "minItems": 4,
          "maxItems": 4
        },
        "live_writeback_debt_statuses": {
          "type": "array",
          "items": {
            "enum": [
              "clean",
              "has_unmarked_changes",
              "needs_marker",
              "not_applicable",
              "unknown"
            ]
          },
          "minItems": 5,
          "maxItems": 5
        }
      },
      "additionalProperties": true
    },
    "writeback_surface": {
      "type": "object",
      "required": [
        "owner",
        "authority_limit",
        "marker_sources",
        "live_debt_command",
        "judgment_route"
      ],
      "properties": {
        "owner": {
          "const": "8Dionysus"
        },
        "authority_limit": {
          "type": "string"
        },
        "marker_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "live_debt_command": {
          "type": "string"
        },
        "judgment_route": {
          "const": "aoa-memo-writeback"
        }
      },
      "additionalProperties": true
    },
    "reviewed_memory_owner": {
      "const": "aoa-memo"
    },
    "session_evidence_owner": {
      "const": ".aoa"
    },
    "access_plane": {
      "type": "object",
      "required": [
        "name",
        "status",
        "access_plane_owner",
        "authority_owner"
      ],
      "properties": {
        "name": {
          "const": "aoa_memo"
        },
        "status": {
          "enum": [
            "registered",
            "not-registered"
          ]
        },
        "runtime_status": {
          "enum": [
            "not_asserted_by_workspace_map"
          ]
        },
        "access_plane_owner": {
          "const": "abyss-stack"
        },
        "authority_owner": {
          "const": "aoa-memo"
        },
        "service_source_hint": {
          "type": "string"
        },
        "smoke_check": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "totals": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "places": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "role",
          "place_kind",
          "checkout_state",
          "path_hint",
          "memory_role",
          "refactor_state",
          "root_agents_present",
          "memory_route_status",
          "current_port_level",
          "recommended_port_level",
          "reviewed_memory_route",
          "evidence_route",
          "mcp",
          "memo_port",
          "writeback_marker",
          "writeback_debt",
          "validation_command",
          "issues"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "place_kind": {
            "type": "string"
          },
          "checkout_state": {
            "enum": [
              "scanned",
              "missing"
            ]
          },
          "path_hint": {
            "type": "string"
          },
          "memory_role": {
            "type": "string"
          },
          "refactor_state": {
            "type": "string"
          },
          "root_agents_present": {
            "type": "boolean"
          },
          "memory_route_status": {
            "enum": [
              "missing",
              "root_memory_route",
              "local_port_route",
              "session_evidence_route"
            ]
          },
          "current_port_level": {
            "enum": [
              "none",
              "route_only",
              "stub_port",
              "full_port",
              "mature_port"
            ]
          },
          "recommended_port_level": {
            "enum": [
              "none",
              "route_only",
              "stub_port",
              "full_port",
              "mature_port"
            ]
          },
          "reviewed_memory_route": {
            "const": "aoa-memo:reviewed-intake"
          },
          "evidence_route": {
            "type": "string",
            "pattern": "^\\.aoa:"
          },
          "mcp": {
            "type": "object"
          },
          "memo_port": {
            "type": "object",
            "required": [
              "present",
              "path_hint",
              "port_level",
              "index_present",
              "missing_files",
              "missing_dirs",
              "local_candidates",
              "validation_receipts",
              "pending_exports",
              "local_records"
            ],
            "properties": {
              "present": {
                "type": "boolean"
              },
              "path_hint": {
                "type": "string"
              },
              "port_level": {
                "enum": [
                  "none",
                  "route_only",
                  "stub_port",
                  "full_port",
                  "mature_port"
                ]
              },
              "local_candidates": {
                "type": "integer",
                "minimum": 0
              },
              "pending_exports": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          },
          "writeback_marker": {
            "type": "object",
            "required": [
              "status",
              "decision",
              "marker_kind",
              "marker_ref",
              "marker_path",
              "source"
            ],
            "properties": {
              "status": {
                "enum": [
                  "present",
                  "missing",
                  "not_applicable",
                  "unknown"
                ]
              },
              "decision": {
                "type": "string"
              },
              "marker_kind": {
                "type": "string"
              },
              "marker_ref": {
                "type": "string"
              },
              "marker_path": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "writeback_debt": {
            "type": "object",
            "required": [
              "status",
              "basis",
              "live_command",
              "next_route"
            ],
            "properties": {
              "status": {
                "enum": [
                  "live_check_required",
                  "needs_marker",
                  "not_applicable",
                  "unknown"
                ]
              },
              "basis": {
                "type": "string"
              },
              "live_command": {
                "type": "string"
              },
              "next_route": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "validation_command": {
            "type": "string"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
